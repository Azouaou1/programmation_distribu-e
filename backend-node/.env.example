# ─── Serveur ───────────────────────────────────────────
PORT=8001
NODE_ENV=development

# ─── Base de données ────────────────────────────────────
# SQLite (développement local)
DB_DIALECT=sqlite
DB_STORAGE=./neurovent.sqlite

# PostgreSQL via URL complète (Render — prioritaire si définie)
# DATABASE_URL=postgresql://user:password@host:5432/neurovent

# PostgreSQL via variables séparées (alternative)
# DB_DIALECT=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=neurovent
# DB_USER=postgres
# DB_PASSWORD=yourpassword

# ─── JWT ───────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRES=2h
JWT_REFRESH_EXPIRES=7d

# ─── Email (Gmail SMTP) ─────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=neurovent.noreply@gmail.com
EMAIL_HOST_PASSWORD=your_app_password_here
EMAIL_FROM=Neurovent <neurovent.noreply@gmail.com>

# ─── Frontend ───────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Compte admin initial ────────────────────────────────
ADMIN_EMAIL=admin@neurovent.com
ADMIN_PASSWORD=admin123

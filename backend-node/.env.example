# ============================================================
#  Neurovent — Backend Node.js — Variables d'environnement
# ============================================================

# Serveur
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=change_me_in_production_use_a_long_random_string
JWT_ACCESS_EXPIRES=2h
JWT_REFRESH_EXPIRES=7d

# Frontend (pour les liens dans les emails)
FRONTEND_URL=http://localhost:5173

# Email SMTP (Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=neurovent.noreply@gmail.com
EMAIL_PASS=votre_app_password_google_16_caracteres
EMAIL_FROM=Neurovent <neurovent.noreply@gmail.com>

# Base de données SQLite (chemin relatif depuis la racine)
DB_PATH=./neurovent.sqlite
